<Window x:Class="FileEncryptor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FileEncryptor.ViewModels"
        mc:Ignorable="d"
        Title="File Encryptor"
        Height="720" Width="1000"
        MinHeight="520" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}"
        Icon="app.ico"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        SizeChanged="Window_SizeChanged">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════ 标题栏 + Logo ═══════ -->
        <DockPanel Grid.Row="0" Margin="4,0,4,12">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <!-- 酷炫 Logo -->
                <Grid Width="42" Height="42" Margin="0,0,12,0">
                    <Grid.RenderTransform>
                        <RotateTransform x:Name="LogoRotation" Angle="0"/>
                    </Grid.RenderTransform>
                    <Grid.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="LogoRotation"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360" Duration="0:0:8"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Grid.Triggers>
                    <!-- 外圈 -->
                    <Ellipse Stroke="{StaticResource AccentGradient}" StrokeThickness="2" Opacity="0.6"/>
                    <!-- 内圈 -->
                    <Ellipse Stroke="{StaticResource AccentGradient}" StrokeThickness="1.5" Opacity="0.3"
                             Width="28" Height="28" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <!-- 中心锁图标 -->
                    <TextBlock Text="&#x1F512;" FontSize="16" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    <!-- 光晕 -->
                    <Ellipse Width="48" Height="48" Opacity="0.15">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="{StaticResource AccentGradientStart}" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                </Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="File Encryptor" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="AES-256 加密 / 解密" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,1,0,0"/>
                </StackPanel>
            </StackPanel>

            <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                       FontSize="11" Foreground="{StaticResource AccentGradientStartBrush}"
                       Text="{Binding FileCount, StringFormat='{}{0} 个文件待处理'}"/>
        </DockPanel>

        <!-- ═══════ 主内容区 ═══════ -->
        <Grid x:Name="MainGrid" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftColumn" Width="260" MinWidth="220" MaxWidth="340"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── 左侧：操作面板 ─── -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="操作设置" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,14"/>

                        <!-- 操作模式 -->
                        <TextBlock Text="模式" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,5"/>
                        <ComboBox Style="{StaticResource DarkComboBox}"
                                  SelectedIndex="{Binding OperationMode}" Margin="0,0,0,14">
                            <ComboBoxItem Content="&#x1F512; 加密" Style="{StaticResource DarkComboBoxItem}"/>
                            <ComboBoxItem Content="&#x1F513; 解密" Style="{StaticResource DarkComboBoxItem}"/>
                        </ComboBox>

                        <!-- 密码 -->
                        <TextBlock Text="密码" FontSize="11" Margin="0,0,0,5"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <PasswordBox x:Name="PasswordBoxMain"
                                     Style="{StaticResource DarkPasswordBox}"
                                     Margin="0,0,0,10"
                                     PasswordChanged="PasswordBoxMain_PasswordChanged"/>

                        <TextBlock Text="确认密码" FontSize="11" Margin="0,0,0,5"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <PasswordBox x:Name="PasswordBoxConfirm"
                                     Style="{StaticResource DarkPasswordBox}"
                                     Margin="0,0,0,14"
                                     PasswordChanged="PasswordBoxConfirm_PasswordChanged"/>

                        <!-- 输出方式 -->
                        <TextBlock Text="输出方式" FontSize="11" Margin="0,0,0,5"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <ComboBox Style="{StaticResource DarkComboBox}"
                                  SelectedIndex="{Binding OutputMode}" Margin="0,0,0,14">
                            <ComboBoxItem Content="覆盖原文件" Style="{StaticResource DarkComboBoxItem}"/>
                            <ComboBoxItem Content="输出到新文件夹" Style="{StaticResource DarkComboBoxItem}"/>
                        </ComboBox>

                        <!-- 加密后缀名 -->
                        <TextBlock Text="加密后缀名" FontSize="11" Margin="0,0,0,5"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Visibility="{Binding IsEncryptMode, Converter={StaticResource BoolToVis}}"/>
                        <TextBox Text="{Binding CustomExtension, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 Margin="0,0,0,14"
                                 Visibility="{Binding IsEncryptMode, Converter={StaticResource BoolToVis}}"
                                 ToolTip="加密后的文件后缀，默认为 .encrypted"/>

                        <Separator Background="{StaticResource BorderDarkBrush}" Margin="0,4,0,14"/>

                        <!-- 执行按钮 -->
                        <Button Content="{Binding ExecuteButtonText}"
                                Command="{Binding ExecuteCommand}"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                MinHeight="40" FontSize="13" Margin="0,0,0,8"/>

                        <!-- 取消按钮 -->
                        <Button Content="取消"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource DangerButton}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                IsEnabled="{Binding IsProcessing}"
                                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"
                                MinHeight="36" FontSize="12"/>

                        <Separator Background="{StaticResource BorderDarkBrush}" Margin="0,10,0,14"/>

                        <!-- 右键菜单管理 -->
                        <TextBlock Text="右键菜单" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,8"/>
                        <Button Content="&#x2714; 注册右键菜单"
                                Command="{Binding RegisterMenuCommand}"
                                Style="{StaticResource GhostButton}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="0,0,0,6" FontSize="12"/>
                        <Button Content="&#x2716; 卸载右键菜单"
                                Command="{Binding UnregisterMenuCommand}"
                                Style="{StaticResource GhostButton}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                FontSize="12"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent" Cursor="SizeWE"/>

            <!-- ─── 右侧：文件列表 + 拖放区 ─── -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 列表标题栏 -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="文件列表" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   Text="{Binding FileCount, StringFormat=（{0}）}"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Content="选择文件" Command="{Binding SelectFilesCommand}"
                                    Style="{StaticResource GhostButton}"/>
                            <Button Content="选择文件夹" Command="{Binding SelectFolderCommand}"
                                    Style="{StaticResource GhostButton}"/>
                            <Button Content="清空" Command="{Binding ClearCommand}"
                                    Style="{StaticResource GhostButton}"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- 空状态：拖放区域 -->
                    <Border Grid.Row="1" CornerRadius="8"
                            BorderBrush="{StaticResource BorderDarkBrush}"
                            BorderThickness="2"
                            Padding="24" MinHeight="120"
                            AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver"
                            Visibility="{Binding IsListEmpty, Converter={StaticResource BoolToVis}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="{StaticResource BorderDarkBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDragOver}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentGradientStartBrush}"/>
                                        <Setter Property="Background" Value="#15667eea"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#x1F4E4;" FontSize="36" HorizontalAlignment="Center" Opacity="0.6"/>
                            <TextBlock Text="拖拽文件到此处"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,4"/>
                            <TextBlock Text="或点击上方「选择文件」按钮"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" HorizontalAlignment="Center" Opacity="0.6"/>
                        </StackPanel>
                    </Border>

                    <!-- 文件列表 -->
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Files}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Padding="0"
                             Visibility="{Binding IsListVisible, Converter={StaticResource BoolToVis}}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#0A667eea"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#12667eea"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" Margin="0"
                                        BorderBrush="{StaticResource BorderDarkBrush}"
                                        BorderThickness="0,0,0,0.5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>

                                        <!-- 类型图标 -->
                                        <TextBlock Grid.Column="1" Text="{Binding TypeIcon}"
                                                   FontSize="16" VerticalAlignment="Center"
                                                   Margin="0,0,8,0" Width="22" TextAlignment="Center"/>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" MinWidth="0">
                                            <TextBlock Text="{Binding FileName}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="13" FontWeight="Medium"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock FontSize="11" Margin="0,1,0,0"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="{Binding TypeLabel}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                                   FontSize="11" Margin="12,0,0,0" MinWidth="48"
                                                   HorizontalAlignment="Right">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="待处理"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="处理中...">
                                                            <Setter Property="Text" Value="处理中"/>
                                                            <Setter Property="Foreground" Value="{StaticResource WarnOrangeBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="已完成">
                                                            <Setter Property="Text" Value="&#x2714; 完成"/>
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessGreenBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="失败">
                                                            <Setter Property="Text" Value="&#x2716; 失败"/>
                                                            <Setter Property="Foreground" Value="{StaticResource DangerRedBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Button Grid.Column="4" Content="&#x2715;" FontSize="11"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" Padding="6,2" Margin="4,0,0,0"
                                                VerticalAlignment="Center"
                                                Click="RemoveFile_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource DangerRedBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 底部进度 -->
                    <Border Grid.Row="2" Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"
                            Margin="0,10,0,0">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="{Binding ProgressText}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" DockPanel.Dock="Right"
                                           Text="{Binding ProgressValue, StringFormat={}{0:F1}%}"/>
                            </DockPanel>
                            <ProgressBar Value="{Binding ProgressValue}" Maximum="100"
                                         Style="{StaticResource ModernProgressBar}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════ 状态栏 ═══════ -->
        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Margin="0" Padding="14,10">
            <DockPanel>
                <TextBlock Text="AES-256" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentGradientStartBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Border Background="#FF667eea" CornerRadius="3" Padding="6,2" VerticalAlignment="Center"
                        Margin="0,0,12,0">
                    <TextBlock Text="PBKDF2" FontSize="9" Foreground="White" FontWeight="SemiBold"/>
                </Border>
                <TextBlock Text="{Binding StatusText}" FontSize="12"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
